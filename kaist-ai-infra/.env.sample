# Environment Variables Sample
# Copy this file to .env and fill in the values

# Azure Configuration
AZURE_SUBSCRIPTION_ID=<your-azure-subscription-id>
AZURE_TENANT_ID=<your-azure-tenant-id>
AZURE_LOCATION=koreacentral

# Environment
AZURE_ENV_NAME=dev

# Resource Naming
BASE_NAME=kaist-ai-agent
OWNER="KAIST Big Data Analysis Team"
COST_CENTER=KAIST-BDA

# Application Configuration (to be set after deployment)
# AZURE_STORAGE_ACCOUNT_NAME=<generated-after-deployment>
# AZURE_COSMOSDB_ACCOUNT_NAME=<generated-after-deployment>
# AZURE_KEY_VAULT_NAME=<generated-after-deployment>
# AZURE_FUNCTION_APP_NAME=<generated-after-deployment>
# AZURE_STATIC_WEB_APP_NAME=<generated-after-deployment>

# External API Keys (to be stored in Key Vault after deployment)
# OPENAI_API_KEY=<your-openai-api-key>
# GCP_GEMINI_API_KEY=<your-gcp-gemini-api-key>
