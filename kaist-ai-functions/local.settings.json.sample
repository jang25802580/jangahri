{
  "IsEncrypted": false,
  "Values": {
    "AzureWebJobsStorage": "<Azure Storage Account Connection String — from Azure Portal or: az storage account show-connection-string --name <STORAGE_ACCOUNT_NAME> --resource-group kaist-ai-agent-rg>",
    "FUNCTIONS_WORKER_RUNTIME": "python",
    "GOOGLE_API_KEY": "<Gemini API Key — from https://aistudio.google.com/app/apikey>",
    "GOOGLE_CLOUD_PROJECT": "<GCP Project ID — e.g. kaist-ai-agent-123456>",
    "LLM_MODEL": "gemini-2.0-flash",
    "EMBEDDING_MODEL": "models/text-embedding-004",
    "COSMOS_ENDPOINT": "<Azure Cosmos DB Endpoint URL — from Azure Portal or: az cosmosdb show --name <COSMOS_ACCOUNT_NAME> --resource-group kaist-ai-agent-rg --query documentEndpoint>",
    "COSMOS_DATABASE_NAME": "knowledgebase",
    "STORAGE_ACCOUNT_NAME": "<Azure Storage Account Name>",
    "PDF_CONTAINER_NAME": "pdfs",
    "APPLICATIONINSIGHTS_CONNECTION_STRING": "<Application Insights Connection String — from Azure Portal>"
  }
}
